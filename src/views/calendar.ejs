<!DOCTYPE html>
<html>
<head>
  <title>Calendar - Booking Admin</title>
  <%- include('partials/head') %>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/6.1.15/index.global.min.css" rel="stylesheet" onerror="this.remove()">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/fullcalendar/6.1.15/index.global.min.js"></script>
</head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar') %>
  <div class="main">
    <h2>Calendar</h2>
    <p class="muted">Blue = confirmed, green = seated, grey = other/cancelled reference. Events marked 📅 were added directly on Google Calendar. Click a booking to view details.</p>
    <div id="calendar"></div>
  </div>
</div>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    var el = document.getElementById('calendar');
    var calendar = new FullCalendar.Calendar(el, {
      initialView: 'dayGridMonth',
      headerToolbar: { left: 'prev,next today', center: 'title', right: 'dayGridMonth,timeGridWeek,timeGridDay' },
      height: 'auto',
      events: '/calendar/api/events',
      eventClick: function(info) {
        info.jsEvent.preventDefault();
        if (info.event.url) window.location = info.event.url;
      }
    });
    calendar.render();
  });
</script>
</body>
</html>

<!DOCTYPE html>
<html>
<head><title>Roster - Weekly Grid - Booking Admin</title><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar') %>
  <div class="main">
    <h2>Roster</h2>
    <%- include('partials/roster-nav') %>

    <p class="muted">This repeats every week automatically — set it up once for 24/7 coverage. Pick a staff member and their hours for each day; overlapping bars mean multiple people are working at the same time. Need a one-off change for a single date? Use <a href="/roster/schedule">This Week</a> instead.</p>
    <% if (error) { %><div class="error-box"><%= error %></div><% } %>

    <% if (users.length === 0) { %>
      <div class="card"><p class="muted" style="margin:0">No active staff accounts yet — add staff from the Users page first.</p></div>
    <% } else { %>

      <div class="card">
        <h3 style="margin-top:0">Staff colours</h3>
        <div class="roster-legend">
          <% users.forEach(u => { %>
            <div class="roster-legend-item">
              <span class="roster-legend-swatch" style="background:<%= u.color %>"></span><%= u.name %>
            </div>
          <% }) %>
        </div>
        <p class="muted" style="margin:8px 0 0">Change anyone's colour from the <a href="/users">Users page</a>.</p>
      </div>

      <% weekDays.forEach(dow => { %>
        <div class="card">
          <h3 style="margin-top:0"><%= dayNames[dow] %></h3>

          <form class="roster-add-form" method="POST" action="/roster/assignments">
            <input type="hidden" name="dayOfWeek" value="<%= dow %>">
            <div class="field">
              <label>Staff</label>
              <select name="userId" required>
                <option value="">Choose staff…</option>
                <% users.forEach(u => { %><option value="<%= u.id %>"><%= u.name %></option><% }) %>
              </select>
            </div>
            <div class="field narrow">
              <label>Start</label>
              <input type="time" name="startTime" required>
            </div>
            <div class="field narrow">
              <label>End</label>
              <input type="time" name="endTime" required>
            </div>
            <button class="btn" type="submit">Add to <%= dayNames[dow] %></button>
          </form>

          <% if (byDay[dow].length === 0) { %>
            <p class="muted" style="margin:0">Nothing scheduled.</p>
          <% } else { %>
            <div class="roster-hour-header">
              <% for (let h = 0; h < 24; h += 2) { %><span><%= String(h).padStart(2,'0') %></span><span></span><% } %>
            </div>
            <% byDay[dow].forEach(a => { %>
              <div class="roster-timeline-row">
                <div class="roster-timeline-name" title="<%= a.userName %>"><%= a.userName %></div>
                <div class="roster-timeline-track">
                  <% for (let h = 0; h < 24; h++) { %><div class="roster-hour-cell"></div><% } %>
                  <div class="roster-timeline-bar" style="left:<%= a.leftPct %>%;width:<%= a.widthPct %>%;background:<%= a.color %>">
                    <span><%= a.startTime %>–<%= a.endTime %></span>
                  </div>
                </div>
                <form class="inline" method="POST" action="/roster/assignments/<%= a.id %>/delete">
                  <button class="roster-timeline-remove" type="submit" title="Remove from weekly pattern">&times;</button>
                </form>
              </div>
            <% }) %>
          <% } %>
        </div>
      <% }) %>

    <% } %>
  </div>
</div>
</body>
</html>

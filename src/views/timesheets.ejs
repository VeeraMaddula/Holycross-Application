<!DOCTYPE html>
<html>
<head><title>Timesheets - Booking Admin</title><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar') %>
  <div class="main">
    <h2>Timesheets</h2>
    <p class="muted">Clock in/out and break history with selfie verification. Visible to Admin, Senior Manager, Floor Manager, and anyone else individually granted access on the Users page.</p>

    <% const canEditTimesheets = currentUser && (currentUser.role === 'admin' || currentUser.role === 'senior_manager'); %>

    <form class="filters" method="GET" action="/timesheets">
      <div class="field">
        <label>Staff member</label>
        <select name="userId">
          <option value="">All staff</option>
          <% users.forEach(u => { %>
            <option value="<%= u.id %>" <%= String(filterUserId) === String(u.id) ? 'selected' : '' %>><%= u.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="field">
        <label>From</label>
        <input type="date" name="from" value="<%= filterFrom %>">
      </div>
      <div class="field">
        <label>To</label>
        <input type="date" name="to" value="<%= filterTo %>">
      </div>
      <button class="btn secondary" type="submit">Filter</button>
      <a class="btn secondary" href="/timesheets">Clear</a>
      <a class="btn small" href="/timesheets/export?userId=<%= filterUserId %>&from=<%= filterFrom %>&to=<%= filterTo %>">Download CSV (hours worked)</a>
    </form>

    <% if (canEditTimesheets) { %>
    <div class="card" style="max-width:560px">
      <h3 style="margin-top:0">Correct a missed clock in/out</h3>
      <p class="muted">For when someone forgets to tap in or out on the kiosk.</p>
      <% if (addError) { %><div class="error-box"><%= addError %></div><% } %>
      <form method="POST" action="/timesheets" class="form-grid">
        <div class="field">
          <label>Staff member</label>
          <select name="userId" required>
            <% users.forEach(u => { %>
              <option value="<%= u.id %>"><%= u.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="field">
          <label>Action</label>
          <select name="action" required>
            <option value="clock_in">Clocked in</option>
            <option value="clock_out">Clocked out</option>
            <option value="break_start">Started break</option>
            <option value="break_end">Ended break</option>
          </select>
        </div>
        <div class="field">
          <label>Date &amp; time</label>
          <input type="datetime-local" name="at" required>
        </div>
        <div class="field full">
          <button class="btn small" type="submit">Add entry</button>
        </div>
      </form>
    </div>
    <% } %>

    <div class="card">
      <h3 style="margin-top:0"><%= isRangeCustom ? 'Summary for selected range' : "Today's summary" %></h3>
      <% if (summary.length === 0) { %>
        <p class="muted">No clock activity in this range yet.</p>
      <% } else { %>
        <table>
          <thead><tr><th>Staff</th><th>Worked</th><th>Break</th></tr></thead>
          <tbody>
          <% summary.forEach(s => { %>
            <tr>
              <td><%= s.user.name %></td>
              <td><%= Math.floor(s.workedMinutes / 60) %>h <%= s.workedMinutes % 60 %>m</td>
              <td><%= Math.floor(s.breakMinutes / 60) %>h <%= s.breakMinutes % 60 %>m</td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div class="card">
      <h3 style="margin-top:0">Full log</h3>
      <% if (entries.length === 0) { %>
        <p class="muted">No entries match this filter.</p>
      <% } else { %>
        <table>
          <thead><tr><th>Photo</th><th>Staff</th><th>Action</th><th>Date &amp; time</th><th>Hours worked</th><th>Break time</th><% if (canEditTimesheets) { %><th></th><% } %></tr></thead>
          <tbody>
          <% entries.forEach(e => { %>
            <tr>
              <td>
                <% if (e.selfiePath) { %>
                  <a href="<%= e.selfiePath %>" target="_blank" rel="noopener">
                    <img src="<%= e.selfiePath %>" alt="Selfie" style="width:40px;height:40px;border-radius:50%;object-fit:cover;border:1px solid var(--line)">
                  </a>
                <% } else { %>—<% } %>
              </td>
              <td><%= e.userName %></td>
              <td>
                <span class="badge <%= (e.action === 'clock_in' || e.action === 'break_end') ? 'confirmed' : (e.action === 'break_start' ? 'status-skipped-no-smtp' : 'cancelled') %>">
                  <%= ({ clock_in: 'Clocked in', clock_out: 'Clocked out', break_start: 'Started break', break_end: 'Ended break' })[e.action] || e.action %>
                </span>
                <% if (e.manuallyAdded) { %><div class="muted" style="font-size:11px;margin-top:2px">Added by <%= e.editedBy || 'a manager' %></div><% } %>
                <% if (e.edited) { %><div class="muted" style="font-size:11px;margin-top:2px">Edited by <%= e.editedBy || 'a manager' %></div><% } %>
              </td>
              <td><%= new Date(e.at).toLocaleString() %></td>
              <td><%= e.shiftTotals ? (Math.floor(e.shiftTotals.workedMinutes / 60) + 'h ' + (e.shiftTotals.workedMinutes % 60) + 'm') : '—' %></td>
              <td><%= e.shiftTotals ? (Math.floor(e.shiftTotals.breakMinutes / 60) + 'h ' + (e.shiftTotals.breakMinutes % 60) + 'm') : '—' %></td>
              <% if (canEditTimesheets) { %>
                <td style="white-space:nowrap">
                  <a class="btn small secondary" href="/timesheets/<%= e.id %>/edit">Edit</a>
                  <form class="inline" method="POST" action="/timesheets/<%= e.id %>/delete" onsubmit="return confirm('Delete this clock entry?')">
                    <button class="btn small danger" type="submit">Delete</button>
                  </form>
                </td>
              <% } %>
            </tr>
          <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>
</body>
</html>

<!DOCTYPE html>
<html>
<head><title>My Shifts - Booking Admin</title><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar') %>
  <div class="main">
    <h2>My Shifts</h2>
    <p class="muted">Your upcoming shifts for the next 4 weeks.</p>

    <div class="card">
      <% if (days.length === 0) { %>
        <p class="muted">No upcoming shifts scheduled for you right now.</p>
      <% } else { %>
        <table>
          <thead><tr><th>Date</th><th>Time</th></tr></thead>
          <tbody>
          <% days.forEach(day => { %>
            <% day.shifts.forEach(s => { %>
              <tr>
                <td><%= dayNames[day.dayOfWeek] %>, <%= new Date(day.date + 'T00:00:00').toLocaleDateString() %></td>
                <td><span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:<%= s.color %>;margin-right:6px;vertical-align:middle"></span><%= formatTime12(s.startTime) %>–<%= formatTime12(s.endTime) %></td>
              </tr>
            <% }) %>
          <% }) %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>
</div>
</body>
</html>

<!DOCTYPE html>
<html>
<head><title>Roster - This Week - Booking Admin</title><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar') %>
  <div class="main">
    <h2>Roster</h2>
    <%- include('partials/roster-nav') %>

    <p class="muted">This is the actual schedule for this week, worked out from the weekly grid. Removing someone here only affects this one date — the weekly grid stays the same for other weeks.</p>

    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
        <strong><%= weekStart %> to <%= weekEnd %></strong>
        <div style="display:flex;gap:8px">
          <a class="btn small secondary" href="/roster/schedule?week=<%= prevWeek %>">&larr; Prev</a>
          <a class="btn small secondary" href="/roster/schedule?week=<%= thisWeek %>">This week</a>
          <a class="btn small secondary" href="/roster/schedule?week=<%= nextWeek %>">Next &rarr;</a>
        </div>
      </div>
    </div>

    <% days.forEach(day => { %>
      <div class="card">
        <h3 style="margin-top:0"><%= dayNames[day.dayOfWeek] %>, <%= day.date %></h3>

        <% if (day.shifts.length === 0) { %>
          <p class="muted">No one scheduled.</p>
        <% } else { %>
          <div class="roster-hour-header">
            <% for (let h = 0; h < 24; h += 2) { %><span><%= String(h).padStart(2,'0') %></span><span></span><% } %>
          </div>
          <% day.shifts.forEach(s => { %>
            <div class="roster-timeline-row">
              <div class="roster-timeline-name" title="<%= s.userName %>">
                <%= s.userName %><% if (s.fromOverride) { %> <span class="muted" style="font-weight:400">*</span><% } %>
              </div>
              <div class="roster-timeline-track">
                <% for (let h = 0; h < 24; h++) { %><div class="roster-hour-cell"></div><% } %>
                <div class="roster-timeline-bar" style="left:<%= s.leftPct %>%;width:<%= s.widthPct %>%;background:<%= s.color %>">
                  <span><%= s.startTime %>–<%= s.endTime %></span>
                </div>
              </div>
              <% if (s.fromOverride) { %>
                <form class="inline" method="POST" action="/roster/overrides/<%= s.overrideId %>/delete">
                  <input type="hidden" name="redirectWeek" value="<%= weekStart %>">
                  <button class="roster-timeline-remove" type="submit" title="Remove this one-off addition">&times;</button>
                </form>
              <% } else { %>
                <form class="inline" method="POST" action="/roster/overrides" onsubmit="return confirm('Remove <%= s.userName %> from this one date only? The weekly grid stays the same for other weeks.')">
                  <input type="hidden" name="date" value="<%= day.date %>">
                  <input type="hidden" name="assignmentId" value="<%= s.assignmentId %>">
                  <input type="hidden" name="type" value="remove">
                  <input type="hidden" name="redirectWeek" value="<%= weekStart %>">
                  <button class="roster-timeline-remove" type="submit" title="Remove for this date only">&times;</button>
                </form>
              <% } %>
            </div>
          <% }) %>
          <p class="muted" style="margin:2px 0 0;font-size:11px">* added just for this date</p>
        <% } %>

        <% if (users.length > 0) { %>
          <details style="margin-top:10px">
            <summary style="cursor:pointer;color:var(--accent-dark);font-size:13px;font-weight:600">+ Add cover for this date only</summary>
            <form class="inline" method="POST" action="/roster/overrides" style="display:flex;gap:6px;margin-top:8px;flex-wrap:wrap;align-items:center">
              <input type="hidden" name="date" value="<%= day.date %>">
              <input type="hidden" name="type" value="add">
              <input type="hidden" name="redirectWeek" value="<%= weekStart %>">
              <select name="userId" required style="width:auto">
                <option value="">Staff member…</option>
                <% users.forEach(u => { %><option value="<%= u.id %>"><%= u.name %></option><% }) %>
              </select>
              <input type="time" name="startTime" required style="width:auto">
              <input type="time" name="endTime" required style="width:auto">
              <button class="btn small secondary" type="submit">Add</button>
            </form>
          </details>
        <% } %>
      </div>
    <% }) %>
  </div>
</div>
</body>
</html>

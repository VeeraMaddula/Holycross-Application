<!DOCTYPE html>
<html>
<head><title>Settings - Booking Admin</title><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar') %>
  <div class="main">
    <h2>Settings</h2>
    <div class="card" style="max-width:480px">
      <form method="POST" action="/settings">
        <div class="field">
          <label>Default booking duration (minutes)</label>
          <input type="number" name="slotDurationMinutes" min="15" step="15" value="<%= settings.slotDurationMinutes %>">
        </div>
        <div class="field">
          <label>Send reminder this many hours before booking</label>
          <input type="number" name="reminderHoursBefore" min="1" value="<%= settings.reminderHoursBefore %>">
        </div>
        <div class="field">
          <label>Opening hour (24h)</label>
          <input type="number" name="openHour" min="0" max="23" value="<%= settings.openHour %>">
        </div>
        <div class="field">
          <label>Closing hour (24h)</label>
          <input type="number" name="closeHour" min="0" max="23" value="<%= settings.closeHour %>">
        </div>
        <button class="btn" type="submit">Save settings</button>
      </form>
    </div>
    <div class="card" style="max-width:480px">
      <h3 style="margin-top:0">Email setup</h3>
      <p class="muted">Email sending is configured via environment variables in your <code>.env</code> file (SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS, SMTP_FROM, ADMIN_NOTIFICATION_EMAIL). See README for a Gmail example.</p>
    </div>
  </div>
</div>
</body>
</html>

<% if (currentUser) { %>
  <a href="/profile" class="topbar-avatar" title="<%= currentUser.firstName %> — <%= currentUser.roleLabel %>">
    <% if (currentUser.avatarPath) { %>
      <img src="<%= currentUser.avatarPath %>" alt="<%= currentUser.firstName %>">
    <% } else { %>
      <span class="topbar-avatar-placeholder" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 12a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9Zm0 2c-4.14 0-7.5 2.46-7.5 5.5V21h15v-1.5c0-3.04-3.36-5.5-7.5-5.5Z" fill="currentColor"/></svg>
      </span>
    <% } %>
  </a>
<% } %>
<div class="sidebar" id="sidebar">
  <div class="brand">
    <img src="/img/logo.jpeg" alt="The Holy Cross">
    <div class="brand-sub">Booking Admin</div>
    <button type="button" class="menu-toggle" aria-label="Toggle menu" onclick="document.getElementById('sidebar').classList.toggle('open')">&#9776;</button>
  </div>
  <div class="sidebar-body">
    <nav>
      <a href="/" class="<%= currentPath === '/' ? 'active' : '' %>">
        <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1.5"/><rect x="14" y="3" width="7" height="7" rx="1.5"/><rect x="3" y="14" width="7" height="7" rx="1.5"/><rect x="14" y="14" width="7" height="7" rx="1.5"/></svg>
        Dashboard
      </a>
      <% if (!currentUser || !['kitchen_staff', 'kiosk'].includes(currentUser.role)) { %>
        <a href="/bookings" class="<%= currentPath.startsWith('/bookings') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18"/><path d="M8 2v4M16 2v4"/><path d="m8.5 14 2 2 4-4"/></svg>
          Bookings
        </a>
        <a href="/calendar" class="<%= currentPath.startsWith('/calendar') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18"/><path d="M8 2v4M16 2v4"/><path d="M7 13h2M11 13h2M15 13h2M7 17h2M11 17h2"/></svg>
          Calendar
        </a>
        <a href="/tables" class="<%= currentPath.startsWith('/tables') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 3v18M3 12h18"/></svg>
          Tables
        </a>
        <a href="/menu" class="<%= currentPath.startsWith('/menu') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M7 2v7a2 2 0 0 0 4 0V2"/><path d="M9 9v13"/><path d="M17 2c-1.5 0-2.5 1.5-2.5 4s1 4 2.5 4v11"/></svg>
          Menu &amp; Events
        </a>
      <% } %>
      <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'senior_manager' || currentUser.canViewNotifications)) { %>
        <a href="/notifications" class="<%= currentPath.startsWith('/notifications') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M6 8a6 6 0 0 1 12 0c0 5 2 6 2 6H4s2-1 2-6"/><path d="M10 21a2 2 0 0 0 4 0"/></svg>
          Notifications
        </a>
      <% } %>
      <% if (!currentUser || !['kitchen_staff', 'kiosk'].includes(currentUser.role)) { %>
        <a href="/staff-status" class="<%= currentPath.startsWith('/staff-status') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="7" r="4"/><path d="M2 21c0-4 3-7 7-7s7 3 7 7"/><path d="m16 14 2 2 3-3"/></svg>
          Staff Status
        </a>
      <% } %>
      <% if (currentUser && ['kiosk', 'admin', 'senior_manager'].includes(currentUser.role)) { %>
        <a href="/kiosk" class="<%= currentPath.startsWith('/kiosk') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="2"/><path d="M10 18h4"/></svg>
          Clock-in Kiosk
        </a>
      <% } %>
      <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'senior_manager' || currentUser.role === 'floor_manager' || currentUser.canViewTimesheets)) { %>
        <a href="/timesheets" class="<%= currentPath.startsWith('/timesheets') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="4" width="14" height="17" rx="2"/><path d="M9 2h6a1 1 0 0 1 1 1v2H8V3a1 1 0 0 1 1-1Z"/><path d="M8 11h8M8 15h8M8 19h5"/></svg>
          Timesheets
        </a>
      <% } %>
      <% if (currentUser && currentUser.role !== 'kiosk') { %>
        <a href="/my-shifts" class="<%= currentPath.startsWith('/my-shifts') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="17" rx="2"/><path d="M3 9h18"/><path d="M8 2v4M16 2v4"/><circle cx="12" cy="15" r="2.3"/></svg>
          My Shifts
        </a>
      <% } %>
      <% if (currentUser && (currentUser.role === 'admin' || currentUser.role === 'senior_manager' || currentUser.canManageRoster)) { %>
        <a href="/roster" class="<%= currentPath.startsWith('/roster') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="4" rx="1"/><rect x="3" y="10" width="18" height="4" rx="1"/><rect x="3" y="16" width="18" height="4" rx="1"/></svg>
          Roster
        </a>
      <% } %>
      <% if (currentUser && (['admin', 'senior_manager', 'general_manager', 'floor_manager', 'bar_staff', 'kitchen_staff'].includes(currentUser.role) || currentUser.canMakeRequests)) { %>
        <a href="/requests" class="<%= currentPath.startsWith('/requests') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 3 3 10.5l7.5 3L14 21l7-18Z"/><path d="M10.5 13.5 21 3"/></svg>
          Requests
        </a>
      <% } %>
      <% if (currentUser && ['bar_staff', 'admin', 'senior_manager'].includes(currentUser.role)) { %>
        <a href="/duties" class="<%= currentPath.startsWith('/duties') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="m9 11 3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
          Duties
        </a>
      <% } %>
      <% if (currentUser && currentUser.role === 'admin') { %>
        <a href="/settings" class="<%= currentPath.startsWith('/settings') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          Settings
        </a>
        <a href="/users" class="<%= currentPath.startsWith('/users') ? 'active' : '' %>">
          <svg class="nav-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="8" r="3.5"/><path d="M2.5 20c0-3.6 2.9-6.5 6.5-6.5s6.5 2.9 6.5 6.5"/><circle cx="18" cy="9" r="3"/><path d="M15.5 14c2.9.3 5 2.8 5 6"/></svg>
          Users
        </a>
      <% } %>
    </nav>
    <% if (currentUser && currentUser.role === 'admin') { %>
      <div class="sidebar-danger-zone">
        <div class="sidebar-danger-label">Danger zone</div>
        <form method="POST" action="/settings/clear-data" onsubmit="return confirm('Clear all bookings, notifications, timesheets, roster shifts, and requests?\n\nStaff accounts, tables, and the menu are kept. This cannot be undone.')">
          <button type="submit" class="sidebar-danger-btn">Clear data</button>
        </form>
        <form method="POST" action="/settings/factory-reset" onsubmit="return confirm('This deletes EVERY booking, staff account, table, and menu item, and logs you out.\n\nThis cannot be undone.') &amp;&amp; confirm('Really factory reset? This is your last chance to cancel.')">
          <button type="submit" class="sidebar-danger-btn sidebar-danger-btn-strong">Factory reset</button>
        </form>
      </div>
    <% } %>
    <% if (currentUser) { %>
      <a href="/profile" class="user-card">
        <% if (currentUser.avatarPath) { %>
          <img class="user-avatar" src="<%= currentUser.avatarPath %>" alt="<%= currentUser.firstName %>">
        <% } else { %>
          <span class="user-avatar user-avatar-placeholder" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 12a4.5 4.5 0 1 0 0-9 4.5 4.5 0 0 0 0 9Zm0 2c-4.14 0-7.5 2.46-7.5 5.5V21h15v-1.5c0-3.04-3.36-5.5-7.5-5.5Z" fill="currentColor"/></svg>
          </span>
        <% } %>
        <div class="user-card-text">
          <div class="user-card-name"><%= currentUser.firstName %></div>
          <div class="user-card-role"><%= currentUser.roleLabel %></div>
        </div>
      </a>
    <% } %>
    <form class="logout-form" method="POST" action="/logout">
      <button class="linklike" type="submit">Log out</button>
    </form>
  </div>
</div>

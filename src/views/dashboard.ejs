<!DOCTYPE html>
<html>
<head><title>Dashboard - Booking Admin</title><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar') %>
  <div class="main">
    <h2>Dashboard</h2>

    <div class="dash-stats">
      <div class="dash-stat"><div class="num"><%= stats.todayCount %></div><div class="label">Bookings today</div></div>
      <div class="dash-stat c-blue"><div class="num"><%= stats.todayGuests %></div><div class="label">Guests today</div></div>
      <div class="dash-stat c-purple"><div class="num"><%= stats.confirmedCount %></div><div class="label">Confirmed (all time)</div></div>
      <div class="dash-stat c-amber"><div class="num"><%= stats.totalTables %></div><div class="label">Tables set up</div></div>
      <div class="dash-stat c-live clickable" id="clockedInStat" role="button" tabindex="0"><div class="num"><span class="live-dot"></span><%= stats.workingNowCount %></div><div class="label">Clocked in now<% if (stats.onBreakCount > 0) { %> (<%= stats.onBreakCount %> on break)<% } %></div></div>
    </div>

    <div class="dash-section">
      <div class="dash-section-head">
        <h3><span class="live-dot"></span>Who's working now</h3>
        <a class="btn small secondary" href="/staff-status">Full staff status</a>
      </div>
      <% if (workingNow.length === 0) { %>
        <p class="muted">No one's clocked in right now.</p>
      <% } else { %>
        <div class="dash-table-wrap">
        <table>
          <thead><tr><th>Name</th><th>Clocked in at</th><th>Status</th><th>Break time</th></tr></thead>
          <tbody id="workingNowBody">
          <% workingNow.forEach(s => { %>
            <tr>
              <td><%= s.user.name %></td>
              <td><%= s.clockInAt ? new Date(s.clockInAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) : '—' %></td>
              <td>
                <span class="badge <%= s.status === 'clocked_in' ? 'confirmed' : 'status-skipped-no-smtp' %>">
                  <%= s.status === 'clocked_in' ? 'Present' : 'On break' %>
                </span>
              </td>
              <td class="break-cell" data-break-since="<%= s.status === 'on_break' ? s.since : '' %>">
                <%= s.status === 'on_break' ? '…' : '—' %>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>
        </div>
      <% } %>
    </div>

    <div class="dash-section">
      <div class="dash-section-head">
        <h3>Today's bookings</h3>
        <a class="btn small" href="/bookings/new">+ New booking</a>
      </div>
      <% if (todayBookings.length === 0) { %>
        <p class="muted">No bookings for today yet.</p>
      <% } else { %>
        <div class="dash-table-wrap">
        <table>
          <thead><tr><th>Time</th><th>Customer</th><th>Party</th><th>Table</th><th>Status</th></tr></thead>
          <tbody>
          <% todayBookings.forEach(b => { const t = tables.find(x => x.id === b.tableId); %>
            <tr class="clickable" onclick="window.location='/bookings/<%= b.id %>'">
              <td><%= b.time %></td>
              <td><%= b.customerName %></td>
              <td><%= b.partySize %></td>
              <td><%= t ? t.name : '-' %></td>
              <td><span class="badge <%= b.status %>"><%= b.status %></span></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
        </div>
      <% } %>
    </div>

    <div class="dash-section">
      <div class="dash-section-head">
        <h3>Upcoming bookings</h3>
      </div>
      <% if (upcoming.length === 0) { %>
        <p class="muted">Nothing upcoming.</p>
      <% } else { %>
        <div class="dash-table-wrap">
        <table>
          <thead><tr><th>Date</th><th>Time</th><th>Customer</th><th>Party</th></tr></thead>
          <tbody>
          <% upcoming.forEach(b => { %>
            <tr class="clickable" onclick="window.location='/bookings/<%= b.id %>'">
              <td><%= b.date %></td>
              <td><%= b.time %></td>
              <td><%= b.customerName %></td>
              <td><%= b.partySize %></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<div class="drawer-overlay" id="workingNowOverlay"></div>
<div class="drawer-panel" id="workingNowDrawer" role="dialog" aria-label="Who's clocked in now">
  <div class="drawer-header">
    <h3><span class="live-dot"></span> Who's clocked in now</h3>
    <button type="button" class="drawer-close" id="workingNowClose" aria-label="Close">&times;</button>
  </div>
  <div class="drawer-body" id="workingNowDrawerBody">
    <% if (workingNow.length === 0) { %>
      <p class="muted">No one's clocked in right now.</p>
    <% } else { %>
      <% workingNow.forEach(s => { %>
        <div class="drawer-person">
          <% if (s.user.avatarPath) { %>
            <img class="drawer-person-avatar" src="<%= s.user.avatarPath %>" alt="<%= s.user.name %>">
          <% } else { %>
            <span class="drawer-person-avatar drawer-person-initials"><%= s.user.name.split(' ').map(p => p[0]).join('').toUpperCase() %></span>
          <% } %>
          <div class="drawer-person-info">
            <div class="drawer-person-name"><%= s.user.name %></div>
            <div class="drawer-person-meta">
              <span class="badge <%= s.status === 'clocked_in' ? 'confirmed' : 'status-skipped-no-smtp' %>"><%= s.status === 'clocked_in' ? 'Present' : 'On break' %></span>
              <span class="muted">In since <%= s.clockInAt ? new Date(s.clockInAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) : '—' %></span>
            </div>
            <% if (s.status === 'on_break') { %>
              <div class="muted break-cell" data-break-since="<%= s.since %>" style="margin-top:3px">…</div>
            <% } %>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>
</div>

<script>
  // "Who's working now" break timers tick locally every second (no server
  // round-trip needed for that), and the whole table refreshes every 20s
  // from the same live endpoint the Staff Status page uses, so a shift
  // change (clock in/out, break start/end) shows up here without a reload.
  function escapeHtml(str) {
    var div = document.createElement('div');
    div.textContent = str == null ? '' : String(str);
    return div.innerHTML;
  }
  function formatDuration(ms) {
    if (ms < 0) ms = 0;
    var totalSec = Math.floor(ms / 1000);
    var h = Math.floor(totalSec / 3600);
    var m = Math.floor((totalSec % 3600) / 60);
    return (h > 0 ? h + 'h ' : '') + m + 'm';
  }

  function tickBreakTimers() {
    document.querySelectorAll('.break-cell').forEach(function(cell) {
      var since = cell.getAttribute('data-break-since');
      cell.textContent = since ? formatDuration(Date.now() - new Date(since).getTime()) : '—';
    });
  }
  tickBreakTimers();
  setInterval(tickBreakTimers, 1000);

  function renderWorkingNow(staff) {
    var workingNow = staff.filter(function(s) { return s.status === 'clocked_in' || s.status === 'on_break'; });
    var body = document.getElementById('workingNowBody');
    if (!body) return;
    var rows = workingNow.map(function(s) {
      var statusClass = s.status === 'clocked_in' ? 'confirmed' : 'status-skipped-no-smtp';
      var statusLabel = s.status === 'clocked_in' ? 'Present' : 'On break';
      var clockInAt = s.clockInAt ? new Date(s.clockInAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) : '—';
      var breakSince = s.status === 'on_break' ? s.since : '';
      return '<tr><td>' + escapeHtml(s.user.name) + '</td><td>' + escapeHtml(clockInAt) + '</td>' +
        '<td><span class="badge ' + statusClass + '">' + statusLabel + '</span></td>' +
        '<td class="break-cell" data-break-since="' + escapeHtml(breakSince) + '">' + (breakSince ? '…' : '—') + '</td></tr>';
    });
    body.innerHTML = rows.join('');
    tickBreakTimers();
  }

  function renderWorkingNowDrawer(staff) {
    var workingNow = staff.filter(function(s) { return s.status === 'clocked_in' || s.status === 'on_break'; });
    var body = document.getElementById('workingNowDrawerBody');
    if (!body) return;
    if (!workingNow.length) {
      body.innerHTML = '<p class="muted">No one\'s clocked in right now.</p>';
      return;
    }
    var cards = workingNow.map(function(s) {
      var statusClass = s.status === 'clocked_in' ? 'confirmed' : 'status-skipped-no-smtp';
      var statusLabel = s.status === 'clocked_in' ? 'Present' : 'On break';
      var clockInAt = s.clockInAt ? new Date(s.clockInAt).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}) : '—';
      var name = escapeHtml(s.user.name);
      var initials = escapeHtml(s.user.name.split(' ').map(function(p) { return p[0]; }).join('').toUpperCase());
      var avatar = s.user.avatarPath
        ? '<img class="drawer-person-avatar" src="' + escapeHtml(s.user.avatarPath) + '" alt="' + name + '">'
        : '<span class="drawer-person-avatar drawer-person-initials">' + initials + '</span>';
      var breakSince = s.status === 'on_break' ? s.since : '';
      var breakRow = breakSince
        ? '<div class="muted break-cell" data-break-since="' + escapeHtml(breakSince) + '" style="margin-top:3px">…</div>'
        : '';
      return '<div class="drawer-person">' + avatar +
        '<div class="drawer-person-info"><div class="drawer-person-name">' + name + '</div>' +
        '<div class="drawer-person-meta"><span class="badge ' + statusClass + '">' + statusLabel + '</span>' +
        '<span class="muted">In since ' + escapeHtml(clockInAt) + '</span></div>' + breakRow + '</div></div>';
    });
    body.innerHTML = cards.join('');
    tickBreakTimers();
  }

  setInterval(function() {
    fetch('/staff-status/data', { headers: { Accept: 'application/json' } })
      .then(function(res) { return res.json(); })
      .then(function(staff) { renderWorkingNow(staff); renderWorkingNowDrawer(staff); })
      .catch(function() { /* silent — keep showing the last known state */ });
  }, 20000);

  // "Clocked in now" stat opens a slide-in panel on the right with everyone
  // currently on the clock — same live data as the table above, just a
  // quicker glance without scrolling down the page.
  (function() {
    var statTile = document.getElementById('clockedInStat');
    var overlay = document.getElementById('workingNowOverlay');
    var drawer = document.getElementById('workingNowDrawer');
    var closeBtn = document.getElementById('workingNowClose');
    if (!statTile || !overlay || !drawer) return;

    function openDrawer() {
      overlay.classList.add('open');
      drawer.classList.add('open');
    }
    function closeDrawer() {
      overlay.classList.remove('open');
      drawer.classList.remove('open');
    }
    statTile.addEventListener('click', openDrawer);
    statTile.addEventListener('keydown', function(e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openDrawer(); }
    });
    closeBtn.addEventListener('click', closeDrawer);
    overlay.addEventListener('click', closeDrawer);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeDrawer();
    });
  })();
</script>
</body>
</html>

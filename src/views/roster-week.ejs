<!DOCTYPE html>
<html>
<head><title>Roster - Booking Admin</title><%- include('partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('partials/sidebar') %>
  <div class="main">
    <h2>Roster</h2>
    <p class="muted">Assign staff directly to a specific date and time — nothing repeats automatically, so what you see here is always exactly who's working. Overlapping bars mean multiple people are on at the same time. Staff get an email and text as soon as a shift is added or edited. Change anyone's colour from the <a href="/users">Users page</a>.</p>

    <div class="card">
      <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
        <strong><%= weekStart %> to <%= weekEnd %></strong>
        <div style="display:flex;gap:8px">
          <a class="btn small secondary" href="/roster/week?week=<%= prevWeek %>">&larr; Prev</a>
          <a class="btn small secondary" href="/roster/week?week=<%= thisWeek %>">This week</a>
          <a class="btn small secondary" href="/roster/week?week=<%= nextWeek %>">Next &rarr;</a>
        </div>
      </div>
    </div>

    <% if (users.length === 0) { %>
      <div class="card"><p class="muted" style="margin:0">No active staff accounts yet — add staff from the Users page first.</p></div>
    <% } else { %>

      <div class="card roster-table-card">
        <h3 style="margin-top:0">Week at a glance</h3>
        <p class="muted" style="margin-top:-6px">Tap a shift to jump to that day. Refreshes automatically — no need to reload.</p>
        <div class="roster-table-wrap">
          <table class="roster-table" id="rosterOverviewTable">
            <thead>
              <tr>
                <th class="roster-table-corner">Staff</th>
                <% days.forEach(day => { %>
                  <th><a href="#day-<%= day.date %>" title="<%= dayNames[day.dayOfWeek] %>, <%= day.date %>"><%= dayNames[day.dayOfWeek].slice(0, 3) %><br><span class="muted" style="font-weight:400"><%= day.date.slice(8) %></span></a></th>
                <% }) %>
              </tr>
            </thead>
            <tbody>
              <% users.forEach(u => { %>
                <tr>
                  <td class="roster-table-name"><%= u.name %></td>
                  <% days.forEach(day => { const cellShifts = day.shifts.filter(s => s.userId === u.id); %>
                    <td class="roster-table-cell" data-user-id="<%= u.id %>" data-date="<%= day.date %>">
                      <% if (cellShifts.length === 0) { %>
                        <span class="roster-table-off">—</span>
                      <% } else { %>
                        <% cellShifts.forEach(s => { %>
                          <a class="roster-pill" href="#day-<%= day.date %>" style="background:<%= s.color %>"><%= formatTime12(s.startTime) %>–<%= formatTime12(s.endTime) %></a>
                        <% }) %>
                      <% } %>
                    </td>
                  <% }) %>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <% days.forEach(day => { %>
        <div class="card" id="day-<%= day.date %>">
          <h3 style="margin-top:0"><%= dayNames[day.dayOfWeek] %>, <%= day.date %></h3>

          <form class="roster-add-form" method="POST" action="/roster/shifts">
            <input type="hidden" name="date" value="<%= day.date %>">
            <input type="hidden" name="redirectWeek" value="<%= weekStart %>">
            <div class="field">
              <label>Staff</label>
              <select name="userId" required>
                <option value="">Choose staff…</option>
                <% users.forEach(u => { %><option value="<%= u.id %>"><%= u.name %></option><% }) %>
              </select>
            </div>
            <div class="field narrow">
              <label>Start</label>
              <input type="time" name="startTime" required>
            </div>
            <div class="field narrow">
              <label>End</label>
              <input type="time" name="endTime" required>
            </div>
            <button class="btn" type="submit">Add to <%= dayNames[day.dayOfWeek] %></button>
          </form>

          <% if (day.shifts.length === 0) { %>
            <p class="muted" style="margin:0">Nothing scheduled.</p>
          <% } else { %>
            <div class="roster-hour-header">
              <% for (let h = 0; h < 24; h += 2) { %><span><%= formatTime12(String(h).padStart(2,'0') + ':00') %></span><span></span><% } %>
            </div>
            <% day.shifts.forEach(s => { %>
              <div class="roster-timeline-row">
                <div class="roster-timeline-name" title="<%= s.userName %>"><%= s.userName %></div>
                <div class="roster-timeline-track">
                  <% for (let h = 0; h < 24; h++) { %><div class="roster-hour-cell"></div><% } %>
                  <div class="roster-timeline-bar" style="left:<%= s.leftPct %>%;width:<%= s.widthPct %>%;background:<%= s.color %>">
                    <span><%= formatTime12(s.startTime) %>–<%= formatTime12(s.endTime) %></span>
                  </div>
                </div>
                <button type="button" class="roster-timeline-remove" title="Edit this shift" style="font-size:15px"
                  onclick="var f=document.getElementById('edit-<%= s.id %>'); f.style.display = f.style.display==='none' ? 'flex' : 'none';">&#9998;</button>
                <form class="inline" method="POST" action="/roster/shifts/<%= s.id %>/delete">
                  <input type="hidden" name="redirectWeek" value="<%= weekStart %>">
                  <button class="roster-timeline-remove" type="submit" title="Remove this shift">&times;</button>
                </form>
              </div>
              <div id="edit-<%= s.id %>" style="display:none;margin:0 0 10px 138px;">
                <form class="roster-add-form" method="POST" action="/roster/shifts/<%= s.id %>/edit" style="margin-bottom:0">
                  <input type="hidden" name="redirectWeek" value="<%= weekStart %>">
                  <div class="field narrow"><label>Date</label><input type="date" name="date" value="<%= s.date %>" required></div>
                  <div class="field narrow"><label>Start</label><input type="time" name="startTime" value="<%= s.startTime %>" required></div>
                  <div class="field narrow"><label>End</label><input type="time" name="endTime" value="<%= s.endTime %>" required></div>
                  <button class="btn small secondary" type="submit">Save — will notify <%= s.userName %></button>
                </form>
              </div>
            <% }) %>
          <% } %>
        </div>
      <% }) %>

    <% } %>
  </div>
</div>
<script>
  // "Week at a glance" table stays in sync on its own — polls the same data
  // every 30s and rebuilds just the shift pills, so a shift added/edited
  // from another device (or by another manager) shows up without a reload.
  (function() {
    var table = document.getElementById('rosterOverviewTable');
    if (!table) return;

    function renderRosterCells(shifts) {
      var byCell = {};
      shifts.forEach(function(s) {
        var key = s.userId + '|' + s.date;
        if (!byCell[key]) byCell[key] = [];
        byCell[key].push(s);
      });
      table.querySelectorAll('.roster-table-cell').forEach(function(td) {
        var key = td.getAttribute('data-user-id') + '|' + td.getAttribute('data-date');
        var list = byCell[key] || [];
        var date = td.getAttribute('data-date');
        if (!list.length) {
          td.innerHTML = '<span class="roster-table-off">—</span>';
          return;
        }
        td.innerHTML = list.map(function(s) {
          return '<a class="roster-pill" href="#day-' + date + '" style="background:' + s.color + '">' + s.startLabel + '–' + s.endLabel + '</a>';
        }).join('');
      });
    }

    setInterval(function() {
      fetch('/roster/week/data?week=<%= weekStart %>', { headers: { Accept: 'application/json' } })
        .then(function(r) { return r.json(); })
        .then(function(data) { renderRosterCells(data.shifts); })
        .catch(function() { /* silent — keep showing the last known state */ });
    }, 30000);
  })();
</script>
</body>
</html>

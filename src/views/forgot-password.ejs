<!DOCTYPE html>
<html>
<head>
  <title>Forgot Password - The Holy Cross</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="login-wrap--brand">
    <div class="login-card--brand">
      <img class="login-logo-full" src="/img/logo-full.png" alt="The Holy Cross - Bar & Restaurant, Since 1775">
      <p class="login-tagline">Reset your password.</p>

      <% if (sent) { %>
        <div class="success-box">If that account exists, we've emailed reset instructions to the address on file. The link expires in 1 hour.</div>
        <a href="/login" class="login-forgot-link">Back to log in</a>
      <% } else { %>
        <p class="muted" style="margin:0 0 18px;font-size:13.5px">Enter your username, phone number, or email, and we'll send a reset link to the email on your account.</p>
        <form method="POST" action="/forgot-password">
          <div class="field">
            <label>Username, phone, or email</label>
            <input type="text" name="identifier" required autofocus>
          </div>
          <div class="field">
            <label>Country code (only needed if entering a phone number)</label>
            <select name="countryCode">
              <% countryCodes.forEach(c => { %>
                <option value="<%= c.code %>" <%= c.code === '+353' ? 'selected' : '' %>><%= c.flag %> <%= c.code %></option>
              <% }) %>
            </select>
          </div>
          <button class="btn" type="submit">Send reset link</button>
          <a href="/login" class="login-forgot-link">Back to log in</a>
        </form>
      <% } %>
    </div>
  </div>
</body>
</html>

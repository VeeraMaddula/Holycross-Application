<!DOCTYPE html>
<html>
<head>
  <title>The Holy Cross - Booking Admin</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="login-wrap--brand">
    <div class="login-card--brand">
      <img class="login-logo-full" src="/img/logo-full.png" alt="The Holy Cross - Bar & Restaurant, Since 1775">
      <p class="login-tagline">Booking Admin — sign in to continue.</p>
      <% if (error) { %><div class="error-box"><%= error %></div><% } %>
      <form method="POST" action="/login">
        <div class="field">
          <label>Email</label>
          <input type="email" name="email" required autofocus>
        </div>
        <div class="field">
          <label>Password</label>
          <input type="password" name="password" required>
        </div>
        <button class="btn" type="submit">Log in</button>
      </form>
    </div>
  </div>
</body>
</html>

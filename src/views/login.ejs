<!DOCTYPE html>
<html>
<head>
  <title>The Holy Cross - Booking Admin</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="login-wrap">
    <div class="login-card">
      <img class="login-logo" src="/img/logo.jpeg" alt="The Holy Cross">
      <p class="muted" style="text-align:center;margin-top:-6px">Booking Admin — enter the admin password to continue.</p>
      <% if (error) { %><div class="error-box"><%= error %></div><% } %>
      <form method="POST" action="/login">
        <div class="field">
          <label>Password</label>
          <input type="password" name="password" required autofocus>
        </div>
        <button class="btn" type="submit" style="width:100%">Log in</button>
      </form>
    </div>
  </div>
</body>
</html>

<!DOCTYPE html>
<html>
<head><title>Users - Booking Admin</title><%- include('../partials/head') %></head>
<body>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <div class="main">
    <h2>Users</h2>
    <% if (error) { %><div class="error-box"><%= error %></div><% } %>

    <div class="card">
      <table>
        <thead><tr><th>Name</th><th>Username</th><th>Colour</th><th>Email</th><th>Role</th><th>Status</th><th>Timesheet access</th><th>Roster access</th><th>Requests access</th><th>Function bookings</th><th>Notifications access</th><th>Created</th><th></th></tr></thead>
        <tbody>
        <% users.forEach(u => { %>
          <tr>
            <td><%= u.name %><% if (u.id === currentUserId) { %> <span class="muted">(you)</span><% } %></td>
            <td><%= u.username || '—' %></td>
            <td>
              <form class="inline" method="POST" action="/users/<%= u.id %>/color">
                <input type="color" name="color" value="<%= u.color || '#7a8f6b' %>" onchange="this.form.submit()" style="width:36px;height:28px;padding:2px;cursor:pointer" title="Roster colour for <%= u.name %>">
              </form>
            </td>
            <td><%= u.email %></td>
            <td>
              <form class="inline" method="POST" action="/users/<%= u.id %>/role">
                <select name="role" class="role-select" onchange="this.form.submit()" <%= u.id === currentUserId ? 'disabled' : '' %>>
                  <% roles.forEach(r => { %>
                    <option value="<%= r.value %>" <%= u.role === r.value ? 'selected' : '' %>><%= r.label %></option>
                  <% }) %>
                </select>
              </form>
            </td>
            <td><span class="badge <%= u.active ? 'confirmed' : 'cancelled' %>"><%= u.active ? 'Active' : 'Inactive' %></span></td>
            <td>
              <% if (u.role === 'admin' || u.role === 'senior_manager') { %>
                <span class="badge confirmed">Included in role</span>
              <% } else { %>
                <form class="inline" method="POST" action="/users/<%= u.id %>/timesheet-access">
                  <button class="btn-toggle <%= u.canViewTimesheets ? 'revoke' : 'grant' %>" type="submit">
                    <%= u.canViewTimesheets ? 'Revoke' : 'Grant' %>
                  </button>
                </form>
              <% } %>
            </td>
            <td>
              <% if (u.role === 'admin' || u.role === 'senior_manager') { %>
                <span class="badge confirmed">Included in role</span>
              <% } else { %>
                <form class="inline" method="POST" action="/users/<%= u.id %>/roster-access">
                  <button class="btn-toggle <%= u.canManageRoster ? 'revoke' : 'grant' %>" type="submit">
                    <%= u.canManageRoster ? 'Revoke' : 'Grant' %>
                  </button>
                </form>
              <% } %>
            </td>
            <td>
              <% if (['admin', 'senior_manager', 'general_manager', 'floor_manager', 'bar_staff', 'kitchen_staff'].includes(u.role)) { %>
                <span class="badge confirmed">Included in role</span>
              <% } else { %>
                <form class="inline" method="POST" action="/users/<%= u.id %>/requests-access">
                  <button class="btn-toggle <%= u.canMakeRequests ? 'revoke' : 'grant' %>" type="submit">
                    <%= u.canMakeRequests ? 'Revoke' : 'Grant' %>
                  </button>
                </form>
              <% } %>
            </td>
            <td>
              <% if (u.role === 'admin' || u.role === 'senior_manager') { %>
                <span class="badge confirmed">Included in role</span>
              <% } else { %>
                <form class="inline" method="POST" action="/users/<%= u.id %>/function-bookings-access">
                  <button class="btn-toggle <%= u.canBookFunctions ? 'revoke' : 'grant' %>" type="submit">
                    <%= u.canBookFunctions ? 'Revoke' : 'Grant' %>
                  </button>
                </form>
              <% } %>
            </td>
            <td>
              <% if (u.role === 'admin' || u.role === 'senior_manager') { %>
                <span class="badge confirmed">Included in role</span>
              <% } else { %>
                <form class="inline" method="POST" action="/users/<%= u.id %>/notifications-access">
                  <button class="btn-toggle <%= u.canViewNotifications ? 'revoke' : 'grant' %>" type="submit">
                    <%= u.canViewNotifications ? 'Revoke' : 'Grant' %>
                  </button>
                </form>
              <% } %>
            </td>
            <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
            <td style="white-space:nowrap">
              <a class="btn small secondary" href="/users/<%= u.id %>/edit">Edit</a>
              <% if (u.id !== currentUserId) { %>
                <form class="inline" method="POST" action="/users/<%= u.id %>/toggle-active" onsubmit="return confirm('<%= u.active ? 'Deactivate' : 'Reactivate' %> this user?')">
                  <button class="btn small secondary" type="submit"><%= u.active ? 'Deactivate' : 'Reactivate' %></button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
        </tbody>
      </table>
    </div>

    <div class="card" style="max-width:480px">
      <h3 style="margin-top:0">Add a user</h3>
      <form method="POST" action="/users">
        <div class="field">
          <label>Name</label>
          <input type="text" name="name" required>
        </div>
        <div class="field">
          <label>Username</label>
          <input type="text" name="username" required autocomplete="username">
          <p class="muted" style="margin-top:4px">What this person logs in with, along with their phone number.</p>
        </div>
        <div class="field">
          <label>Email</label>
          <input type="email" name="email" required>
        </div>
        <div class="field">
          <label>Password</label>
          <div style="position:relative">
            <input type="password" name="password" id="newUserPassword" required minlength="8" maxlength="16"
              pattern="(?=.*[a-z])(?=.*[A-Z])(?=.*[^A-Za-z0-9]).{8,16}"
              title="8-16 characters, with at least one uppercase letter, one lowercase letter, and one special character."
              style="padding-right:52px">
            <button type="button" id="toggleNewUserPassword" aria-label="Show password"
              style="position:absolute;right:10px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:12px;font-weight:600;color:var(--accent-dark)">Show</button>
          </div>
          <p class="muted" style="margin-top:4px">8-16 characters, with at least one uppercase letter, one lowercase letter, and one special character.</p>
        </div>
        <div class="field">
          <label>Phone number</label>
          <input type="tel" name="phone" placeholder="089 433 8657" required>
        </div>
        <div class="field">
          <label>Date of birth</label>
          <input type="date" name="dob">
        </div>
        <div class="field">
          <label>Sex</label>
          <select name="sex">
            <option value="">Prefer not to say</option>
            <option value="male">Male</option>
            <option value="female">Female</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div class="field">
          <label>Location</label>
          <input type="text" name="location" placeholder="City / area">
        </div>
        <div class="field">
          <label>Role</label>
          <select name="role">
            <% roles.forEach(r => { %>
              <option value="<%= r.value %>" <%= r.value === 'bar_staff' ? 'selected' : '' %>><%= r.label %></option>
            <% }) %>
          </select>
        </div>
        <p class="muted">Phone number is required so staff get text notifications when a shift is assigned or changed. Admins have full access, including Settings, Users, payments, and deleting bookings. Senior Managers also get Timesheets, Roster, Function bookings, and Notifications automatically. Everyone else (General Manager, Staff Manager, Floor Manager, Bar Staff, Kitchen Staff) can be individually granted any of those using the access toggles above.</p>
        <button class="btn" type="submit">Create user</button>
      </form>
    </div>
  </div>
</div>

<script>
  (function() {
    var input = document.getElementById('newUserPassword');
    var toggle = document.getElementById('toggleNewUserPassword');
    if (!input || !toggle) return;
    toggle.addEventListener('click', function() {
      var showing = input.type === 'text';
      input.type = showing ? 'password' : 'text';
      toggle.textContent = showing ? 'Show' : 'Hide';
      toggle.setAttribute('aria-label', showing ? 'Show password' : 'Hide password');
    });
  })();
</script>
</body>
</html>

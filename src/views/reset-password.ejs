<!DOCTYPE html>
<html>
<head>
  <title>Reset Password - The Holy Cross</title>
  <%- include('partials/head') %>
</head>
<body>
  <div class="login-wrap--brand">
    <div class="login-card--brand">
      <img class="login-logo-full" src="/img/logo-full.png" alt="The Holy Cross - Bar & Restaurant, Since 1775">

      <% if (!valid) { %>
        <p class="login-tagline">This reset link is invalid or has expired.</p>
        <div class="error-box">Reset links only work once and expire after 1 hour. Request a new one below.</div>
        <a href="/forgot-password" class="btn" style="display:block;text-align:center;text-decoration:none">Request a new link</a>
      <% } else { %>
        <p class="login-tagline">Choose a new password.</p>
        <% if (error) { %><div class="error-box"><%= error %></div><% } %>
        <p class="muted" style="margin:0 0 18px;font-size:13px"><%= passwordRules %></p>
        <form method="POST" action="/reset-password/<%= token %>">
          <div class="field">
            <label>New password</label>
            <input type="password" name="password" required autocomplete="new-password" autofocus>
          </div>
          <div class="field">
            <label>Confirm new password</label>
            <input type="password" name="confirmPassword" required autocomplete="new-password">
          </div>
          <button class="btn" type="submit">Set new password</button>
          <a href="/login" class="login-forgot-link">Back to log in</a>
        </form>
      <% } %>
    </div>
  </div>
</body>
</html>

# Copy this file to .env and fill in your own values.

# Port the app runs on
PORT=3000

# Used ONLY the very first time the app starts, to create the initial admin account.
# After that, manage logins from the Users page in the app instead of these values.
ADMIN_EMAIL=admin@holycross.local
ADMIN_PASSWORD=changeme123

# Random string used to sign login sessions (any long random text is fine)
SESSION_SECRET=please-change-this-to-something-random

# --- Email (optional, needed for confirmation/reminder/cancellation emails) ---
# Using Resend (recommended — Gmail App Passwords aren't available on every
# Google account anymore). Sign up free at https://resend.com, verify a domain
# under Domains, then use these SMTP settings with your Resend API key as the
# password. See README for full setup steps.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=resend
SMTP_PASS=your-resend-api-key
SMTP_FROM=bookings@your-verified-domain.com

# Optional: send a copy of every new booking to this address
ADMIN_NOTIFICATION_EMAIL=owner@example.com

# --- SMS (optional, needed for confirmation/reminder/cancellation texts) ---
# Sign up at https://www.twilio.com, buy a phone number, and copy your
# Account SID + Auth Token from the Twilio Console dashboard. See README.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# --- Google Calendar sync (optional) ---
# See README for the one-time Google Cloud Console setup steps.
# Path to the service account JSON key file you download from Google Cloud Console.
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./google-service-account.json
# The calendar you shared with the service account's email address (its "Calendar ID",
# found in that calendar's Settings > Integrate calendar — looks like an email address).
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
# Timezone used when creating events (optional, defaults to Europe/Dublin)
APP_TIMEZONE=Europe/Dublin

# Copy this file to .env and fill in your own values.

# Port the app runs on
PORT=3000

# Password admin staff use to log in to the booking dashboard
ADMIN_PASSWORD=changeme123

# Random string used to sign login sessions (any long random text is fine)
SESSION_SECRET=please-change-this-to-something-random

# --- Email (optional, needed for confirmation/reminder/cancellation emails) ---
# Example using Gmail: create an "App Password" at https://myaccount.google.com/apppasswords
# (regular Gmail passwords won't work with SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Optional: send a copy of every new booking to this address
ADMIN_NOTIFICATION_EMAIL=owner@example.com
